# NevUp Track 2 — environment template.
# `docker compose up` reads sensible defaults from compose.yml; this file is
# only needed when running the app outside Docker.

# Postgres (matches docker-compose.yml defaults)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nevup
POSTGRES_USER=nevup
POSTGRES_PASSWORD=nevup

# JWT signing secret — exact string from the hackathon kick-off deck.
JWT_SECRET=97791d4db2aa5f689c3cc39356ce35762f0a73aa70923039d8ef72a2840a1b02

# OPTIONAL: Anthropic API key. If unset, the coach falls back to a deterministic
# template engine that still satisfies every spec requirement (citations, audit,
# token-by-token streaming). With the key set, real Claude calls are used.
ANTHROPIC_API_KEY=

# Embedding model — runs locally on CPU. Auto-downloaded on first start.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
